# LLM provider (Gemini default)
LLM_PROVIDER=gemini
# Preferred key for Gemini.
GEMINI_API_KEY=
# Backward-compatible alias (used if GEMINI_API_KEY is empty).
OPENAI_API_KEY=
# OpenAI-compatible endpoint for Gemini.
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Native Gemini endpoint used for grounded web chat.
GEMINI_NATIVE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Groq (free) — used for digest generation (more reliable than Gemini free tier for large calls)
GROQ_API_KEY=
# Optional model overrides (Gemini defaults)
# CHAT_MODEL=gemini-2.5-flash
# CHAT_WEB_MODEL=gemini-2.5-flash
# PIPELINE_MODEL=gemini-2.5-flash-lite
# DIGEST_MODEL=gemini-2.5-flash
# PYTHON_INTELLIGENCE_MODEL=gemini-2.5-flash
# Optional: set true to force chat to run without live web search.
# DISABLE_CHAT_WEB_SEARCH=true
# Optional retry tuning for transient 429/5xx errors.
# LLM_RETRY_ATTEMPTS=3
# LLM_RETRY_BASE_MS=500
# LLM_RETRY_MAX_MS=5000

# Supabase (article memory, preferences, briefing_overlay)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram — bot token from @BotFather; chat id = your user or group id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional explicit preference owner id for dashboard/chat/pipeline/digest.
# If set, this overrides TELEGRAM_CHAT_ID for preference reads/writes.
# PREFERENCE_USER_ID=
# Optional: comma-separated ids if several chats may use the bot
# TELEGRAM_ALLOWED_CHAT_IDS=

# Morning digest: Telegram is sent when token + chat id are set. Set to false to email-only.
# SEND_DIGEST_TELEGRAM=false

# Optional email (SMTP) for HTML digest — leave unset to use Telegram-only morning briefing
EMAIL_FROM=
EMAIL_TO=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# Optional (free): enables economic calendar block in digest
FINNHUB_API_KEY=

# Pipeline tuning
# Global + purpose budgets (all reset daily UTC)
MAX_DAILY_AI_CALLS=30
MAX_DAILY_CHAT_CALLS=20
# MAX_DAILY_PIPELINE_AI_CALLS=30
# MAX_DAILY_DIGEST_AI_CALLS=6
PREFILTER_THRESHOLD=55
ALERT_COOLDOWN_HOURS=4
# Set to true to have the hourly pipeline also use AI to score/summarize articles (costs ~1 call per article).
# Default: off — pipeline stores articles with keyword-only prefilter scores; AI is reserved for digest + chat.
# PIPELINE_AI_SCORING=true

# Also email important pipeline alerts (same SMTP as digest). Use true + SMTP vars.
# ALERT_EMAIL_IMPORTANT=true

# ── Vercel dashboard (dashboard/README.md) ─────────────────────
# DASHBOARD_SECRET=
# GITHUB_TOKEN=
# GITHUB_REPO=yourname/Jeff_Agent1
# GITHUB_DISPATCH_REF=main
# TELEGRAM_WEBHOOK_SECRET=

# ── Intelligence Agent data sources (all free) ────────────────

# ACLED: register at acleddata.com — uses OAuth (email+password)
# The adapter fetches a bearer token automatically on each run.
ACLED_EMAIL=
ACLED_PASSWORD=
# Legacy fallback (if OAuth not available): ACLED_API_KEY=

# OpenSky Network: register at opensky-network.org
# REST API: https://opensky-network.org/api  (documented at /apidoc/rest.html)
# Set OPENSKY_AUTH to base64(username:password) for higher rate limits.
# Without auth: 400 req/day. With auth: 4000 req/day.
OPENSKY_AUTH=

# SAM.gov: register at api.sam.gov for free API key
SAM_GOV_API_KEY=

# FAA NOTAMs (optional): register at api.faa.gov
# FAA_CLIENT_ID=
# FAA_CLIENT_SECRET=

# NASA FIRMS (optional): register for MAP_KEY at firms.modaps.eosdis.nasa.gov
# FIRMS_MAP_KEY=

# Sentinel Hub (optional, Phase 4): register at sentinel-hub.com
# Get Client ID + Secret from your Dashboard → User settings → OAuth clients
# Processing API docs: https://docs.sentinel-hub.com/api/latest/api/process/
# SENTINEL_HUB_CLIENT_ID=
# SENTINEL_HUB_CLIENT_SECRET=

# Map page uses MapLibre GL (free, no key needed) with CartoDB dark tiles.
# Optional: for Mapbox satellite/terrain layers, get a token at mapbox.com
# Account → Access Tokens → Create token → check "styles:read" + "styles:tiles"
# NEXT_PUBLIC_MAPBOX_TOKEN=
