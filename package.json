{
  "name": "jeff-intelligence-system",
  "version": "1.0.0",
  "description": "Autonomous intelligence system — monitors news, filters noise, delivers high-signal alerts",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "email": "ts-node src/send_email.ts --daily",
    "email:weekly": "ts-node src/send_email.ts --weekly",
    "chat": "ts-node src/chat_handler.ts --listen",
    "bot": "ts-node src/chat_handler.ts --listen",
    "typecheck": "tsc --noEmit",
    "test": "ts-node tests/unit.test.ts && ts-node lib/__tests__/verification.test.ts",
    "test:unit": "ts-node tests/unit.test.ts",
    "test:verification": "ts-node lib/__tests__/verification.test.ts",
    "test:telegram": "node --env-file=.env ./node_modules/ts-node/dist/bin.js src/test_telegram.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^17.4.2",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.12",
    "@types/nodemailer": "^6.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
