{
  "skill": "news_intel",
  "version": "1.0.0",
  "description": "Wake/sleep schedule for news intelligence assistant",

  "schedule": [
    {
      "time": "07:00",
      "timezone": "America/New_York",
      "task": "morning_briefing",
      "script": "./run_briefing.sh",
      "always_run": true,
      "always_message": true,
      "description": "Full news pipeline — always runs, always sends briefing"
    },
    {
      "time": "10:00",
      "timezone": "America/New_York",
      "task": "breaking_check",
      "script": "./check_breaking.sh",
      "always_run": true,
      "only_message_if": "result.has_breaking == true",
      "description": "Breaking check — only messages if threshold met"
    },
    {
      "time": "13:00",
      "timezone": "America/New_York",
      "task": "breaking_check",
      "script": "./check_breaking.sh",
      "always_run": true,
      "only_message_if": "result.has_breaking == true",
      "description": "Breaking check — only messages if threshold met"
    },
    {
      "time": "16:00",
      "timezone": "America/New_York",
      "task": "breaking_check",
      "script": "./check_breaking.sh",
      "always_run": true,
      "only_message_if": "result.has_breaking == true",
      "description": "Breaking check — only messages if threshold met"
    },
    {
      "time": "19:00",
      "timezone": "America/New_York",
      "task": "breaking_check",
      "script": "./check_breaking.sh",
      "always_run": true,
      "only_message_if": "result.has_breaking == true",
      "description": "Breaking check — only messages if threshold met"
    }
  ],

  "limits": {
    "max_activations_per_day": 5,
    "max_messages_per_day": 5,
    "sleep_between_checks": true,
    "activation_counter_file": "/tmp/news_intel_daily_activations.txt"
  },

  "behavior": {
    "on_no_breaking": "sleep",
    "on_activation_limit_reached": "sleep_until_tomorrow",
    "on_user_message_outside_schedule": "respond_then_sleep"
  }
}
